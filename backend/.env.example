# HealthSathi Backend Environment Variables
# No external AI API keys needed — all AI via AWS IAM roles

# ─── AWS CONFIGURATION ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1       # Bedrock Claude 3.5 Sonnet availability region

# ─── AWS BEDROCK ─────────────────────────────────────────────────────────────
# Model: anthropic.claude-3-5-sonnet-20241022-v2:0
# Access: granted via IAM role — no API key required
# Ensure Bedrock model access is enabled in AWS Console:
# https://console.aws.amazon.com/bedrock/home#/modelaccess
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ─── AWS AI SERVICES (all via IAM — no keys needed) ─────────────────────────
# AWS Rekognition  — medicine image analysis, counterfeit detection
# AWS Textract     — OCR for prescriptions and lab reports
# AWS Translate    — en / hi / mr real-time translation
# AWS Polly        — text-to-speech (Hindi / Marathi / English)
# AWS Transcribe   — voice input (future feature)

# ─── DYNAMODB ────────────────────────────────────────────────────────────────
TABLE_NAME=healthsathi-data-prod

# ─── S3 BUCKETS ──────────────────────────────────────────────────────────────
UPLOAD_BUCKET=healthsathi-uploads-{ACCOUNT_ID}-prod
MODELS_BUCKET=healthsathi-ml-models-{ACCOUNT_ID}
CONTENT_BUCKET=healthsathi-content-{ACCOUNT_ID}

# ─── TIMESTREAM ──────────────────────────────────────────────────────────────
TIMESTREAM_DB=healthsathi-prod
TIMESTREAM_TABLE=HealthMetrics

# ─── SNS ─────────────────────────────────────────────────────────────────────
DOCTOR_ALERTS_TOPIC=arn:aws:sns:us-east-1:{ACCOUNT_ID}:healthsathi-doctor-alerts-prod

# ─── SENTRY (optional — for Lambda error tracking) ───────────────────────────
# SENTRY_DSN=https://...
