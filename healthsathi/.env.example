# HealthSathi Frontend Environment Variables
# Copy this to .env.local and fill in values after backend deploy
# No external AI API keys needed — all AI via AWS Bedrock / Rekognition / Textract

# ─── API GATEWAY (from SAM deploy output) ────────────────────────────────────
VITE_API_BASE_URL=https://REPLACE.execute-api.ap-south-1.amazonaws.com/prod
VITE_API_KEY=REPLACE_ME  # from AWS Console → API Gateway → API Keys

# ─── S3 PRE-SIGNED URL GENERATOR ─────────────────────────────────────────────
# URL of your pre-sign Lambda/endpoint for direct-to-S3 uploads
# (required for Textract OCR and Rekognition image analysis)
VITE_PRESIGN_URL=https://REPLACE.execute-api.ap-south-1.amazonaws.com/prod/api/presign

# ─── APP CONFIG ───────────────────────────────────────────────────────────────
VITE_APP_VERSION=2.0.0
VITE_AWS_REGION=ap-south-1

# ─── AWS AI SERVICES USED (all server-side via Lambda IAM roles) ─────────────
# - AWS Bedrock    Claude 3.5 Sonnet → lab reports, prescriptions, interactions
# - AWS Rekognition                 → medicine scanning, counterfeit detection
# - AWS Textract                    → OCR for handwritten prescriptions / PDFs
# - AWS Translate                   → en ↔ hi ↔ mr real-time translation
# - AWS Polly                       → text-to-speech (Hindi/Marathi/English)
# - AWS SNS                         → SMS alerts for doctors
# - AWS DynamoDB                    → patient data, offline sync
# - AWS Timestream                  → health metric time-series trends
